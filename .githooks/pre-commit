#!/usr/bin/env bash
# Cell Architecture pre-commit hook
# 提交前强制检查：格式、Lint、测试、架构、熵值

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}==> Running pre-commit checks...${NC}"

# 1. 格式检查
echo -e "${YELLOW}[1/5] Checking code format...${NC}"
if ! cargo fmt --all -- --check > /dev/null 2>&1; then
    echo -e "${RED}FAIL: Code formatting is incorrect. Run 'cargo fmt' to fix.${NC}"
    exit 1
fi
echo -e "${GREEN}PASS: Code format OK${NC}"

# 2. Clippy 检查
echo -e "${YELLOW}[2/5] Running clippy...${NC}"
if ! cargo clippy --all-targets --all-features -- -D warnings > /dev/null 2>&1; then
    echo -e "${RED}FAIL: Clippy found issues. Run 'cargo clippy' for details.${NC}"
    exit 1
fi
echo -e "${GREEN}PASS: Clippy OK${NC}"

# 3. 单元测试
echo -e "${YELLOW}[3/5] Running tests...${NC}"
if ! cargo test --lib > /dev/null 2>&1; then
    echo -e "${RED}FAIL: Tests failed. Run 'cargo test' for details.${NC}"
    exit 1
fi
echo -e "${GREEN}PASS: Tests OK${NC}"

# 4. 架构验证
echo -e "${YELLOW}[4/5] Validating architecture...${NC}"
if ! cargo run --bin cell -- arch validate -p . > /dev/null 2>&1; then
    echo -e "${RED}FAIL: Architecture validation failed. Run 'cargo run -- arch validate -p .' for details.${NC}"
    exit 1
fi
echo -e "${GREEN}PASS: Architecture OK${NC}"

# 5. 熵值门禁
echo -e "${YELLOW}[5/5] Checking entropy gate...${NC}"
ENTROPY_SCORE=$(cargo run --bin cell -- entropy check src 2>/dev/null | grep -o '"overall_score": [^,]*' | grep -o '[0-9.]*')
if [ -z "$ENTROPY_SCORE" ]; then
    echo -e "${YELLOW}WARN: Could not read entropy score, skipping gate.${NC}"
else
    echo -e "Entropy score: $ENTROPY_SCORE"
    if (( $(echo "$ENTROPY_SCORE > 5.0" | bc -l 2>/dev/null || echo 0) )); then
        echo -e "${RED}FAIL: Entropy score $ENTROPY_SCORE exceeds threshold 5.0${NC}"
        exit 1
    fi
fi
echo -e "${GREEN}PASS: Entropy OK${NC}"

echo -e "${GREEN}==> All pre-commit checks passed!${NC}"
exit 0
